#| include: false
library(ggplot2)
library(bench)
library(extraDistr) # Para Muestreo por Importancia
set.seed(4205687)
unidad_de_tiempo <- "ms"
n <- 1e6
probabilidad_cobertura <- 0.997
alfa <- 1 - probabilidad_cobertura
percentil <- qnorm(1 - alfa / 2)
#| label: generación (método directo)
# Definimos los límites como variables
a_1 <- 0
b_1 <- 3
a_2 <- 3
b_2 <- 5
genera_valor_aleatorio <- function() {
# Usamos a y b en la generación
runif(1, min = a_1, max = b_1)
}
g <- function(x) {
# Multiplicamos la función por la longitud del intervalo (b - a)
# Así, el promedio de los valores será directamente la Integral.
(2 -( exp(-2*x*sin(pi/3*x)))) * (b_1 - a_1)
}
genera_valor_aleatorio_2 <- function() {
# Usamos a y b en la generación
runif(1, min = a_2, max = b_2)
}
h <- function(x) {
# Multiplicamos la función por la longitud del intervalo (b - a)
# Así, el promedio de los valores será directamente la Integral.
exp(-x*sin((x-3)*(pi/2))) * (b_2 - a_2)
}
#| label: replicación (método directo)
aplica_muestreo_directo <- function(cantidad_replicaciones) {
replicate(cantidad_replicaciones, {
genera_valor_aleatorio() |>
g()
})
}
# Usamos n definido en el setup
valores <- aplica_muestreo_directo(n)
aplica_muestreo_directo_2 <- function(cantidad_replicaciones) {
replicate(cantidad_replicaciones, {
genera_valor_aleatorio_2() |>
h()
})
}
# Usamos n definido en el setup
valores_2 <- aplica_muestreo_directo_2(n)
#| label: convergencia (método directo)
library(ggplot2)
#| label: estimación (método directo)
estimación_directo <- mean(valores)+ mean(valores_2)
varianza_directo <- (var(valores) + var(valores_2)) / n
error_estandar <- sqrt(varianza_directo)
IC_dir <- estimación_directo + c(-1, 1) * error_estandar * percentil
#| label: eficiencia (método directo)
coste_directo <- bench::mark(
aplica_muestreo_directo(n),
iterations = 10,
time_unit = unidad_de_tiempo
)$median
eficiencia_directo <- 1 / (varianza_directo * coste_directo)
#| label: gráfica de la función g
ggplot() +
geom_function(fun = g) +
xlim(0,3)+
xlab("u") +
ylab(expression(g(u)))
ggplot() +
geom_function(fun = h) +
xlim(3, 5)+
xlab("u") +
ylab(expression(g(u)))
#| label: setup
#| include: false
library(ggplot2)
library(bench)
library(extraDistr) # Para Muestreo por Importancia
set.seed(4205687)
unidad_de_tiempo <- "ms"
n <- 1e6
probabilidad_cobertura <- 0.997
alfa <- 1 - probabilidad_cobertura
percentil <- qnorm(1 - alfa / 2)
#| label: generación (método directo)
# Definimos los límites como variables
a_1 <- 0
b_1 <- 2
a_2 <- 3/2
b_2 <- 3
genera_valor_aleatorio <- function() {
# Usamos a y b en la generación
runif(1, min = a_1, max = b_1)
}
g <- function(x) {
# Multiplicamos la función por la longitud del intervalo (b - a)
# Así, el promedio de los valores será directamente la Integral.
(1+ cos((x-1)*pi)) * (b_1 - a_1)
}
genera_valor_aleatorio_2 <- function() {
# Usamos a y b en la generación
runif(1, min = a_2, max = b_2)
}
h <- function(x) {
# Multiplicamos la función por la longitud del intervalo (b - a)
# Así, el promedio de los valores será directamente la Integral.
((x-3/2)*(3-x)) * (b_2 - a_2)
}
#| label: replicación (método directo)
aplica_muestreo_directo <- function(cantidad_replicaciones) {
replicate(cantidad_replicaciones, {
genera_valor_aleatorio() |>
g()
})
}
# Usamos n definido en el setup
valores <- aplica_muestreo_directo(n)
aplica_muestreo_directo_2 <- function(cantidad_replicaciones) {
replicate(cantidad_replicaciones, {
genera_valor_aleatorio_2() |>
h()
})
}
# Usamos n definido en el setup
valores_2 <- aplica_muestreo_directo_2(n)
#| label: estimación (método directo)
estimación_directo <- mean(valores)+ mean(valores_2)
varianza_directo <- (var(valores) + var(valores_2)) / n
error_estandar <- sqrt(varianza_directo)
IC_dir <- estimación_directo + c(-1, 1) * error_estandar * percentil
#| label: gráfica de la función g
ggplot() +
geom_function(fun = g) +
xlim(0,2)+
xlab("u") +
ylab(expression(g(u)))
ggplot() +
geom_function(fun = h) +
xlim(3/2, 3)+
xlab("u") +
ylab(expression(g(u)))
#| label: generación (muestreo estratificado)
estratos <- data.frame(
min = c(0, 1),
max = c(1, 2)
)
cantidad_estratos <- nrow(estratos)
probabilidades_estratos <- (estratos$max - estratos$min)/(b_1-a_1)
genera_valor_aleatorio_en_estrato <- function(número_estrato) {
estrato <- estratos[número_estrato, ]
runif(1, min = estrato$min, max = estrato$max)
}
estratos_2 <- data.frame(
min = c(1.5, 2.25),
max = c(2.25, 3)
)
cantidad_estratos_2 <- nrow(estratos_2)
probabilidades_estratos_2 <- (estratos_2$max - estratos_2$min)/(b_2-a_2)
genera_valor_aleatorio_en_estrato_2 <- function(número_estrato_2) {
estrato <- estratos_2[número_estrato_2, ]
runif(1, min = estrato$min, max = estrato$max)
}
#| label: generación (muestreo estratificado)
estratos <- data.frame(
min = c(0, 1),
max = c(1, 2)
)
cantidad_estratos <- nrow(estratos)
probabilidades_estratos <- (estratos$max - estratos$min)/(b_1-a_1)
genera_valor_aleatorio_en_estrato <- function(número_estrato) {
estrato <- estratos[número_estrato, ]
runif(1, min = estrato$min, max = estrato$max)
}
estratos_2 <- data.frame(
min = c(1.5, 2.25),
max = c(2.25, 3)
)
cantidad_estratos_2 <- nrow(estratos_2)
probabilidades_estratos_2 <- (estratos_2$max - estratos_2$min)/(b_2-a_2)
genera_valor_aleatorio_en_estrato_2 <- function(número_estrato_2) {
estrato <- estratos_2[número_estrato_2, ]
runif(1, min = estrato$min, max = estrato$max)
}
#| label: replicación (muestreo estratificado)
aplica_muestreo_en_estrato <-
function(número_estrato, cantidad_replicaciones) {
replicate(cantidad_replicaciones, {
genera_valor_aleatorio_en_estrato(número_estrato) |>
g()
})
}
fase_de_tanteo <- function(cantidad_replicaciones) {
# Asignación proporcional
n_estratos <-
(cantidad_replicaciones * probabilidades_estratos) |>
ceiling() |> # aseguramos una cantidad entera de valores
pmax(2) # aseguramos al menos dos valores
purrr::map2(
seq_len(cantidad_estratos),
n_estratos,
\(estrato, n_estrato) aplica_muestreo_en_estrato(estrato, n_estrato)
) |>
purrr::map_dbl(sd)
}
fase_de_producción <- function(cantidad_replicaciones, sigmas) {
# Asignación óptima
n_estratos <-
(cantidad_replicaciones * probabilidades_estratos * sigmas /
sum(probabilidades_estratos * sigmas)) |>
ceiling() |> # aseguramos una cantidad entera de valores
pmax(2) # aseguramos al menos dos valores
purrr::map2(
seq_len(cantidad_estratos),
n_estratos,
\(estrato, n_estrato) aplica_muestreo_en_estrato(estrato, n_estrato)
)
}
sigmas <- fase_de_tanteo(100)
valores_estratos <- fase_de_producción(n, sigmas)
aplica_muestreo_en_estrato_2 <-
function(número_estrato, cantidad_replicaciones) {
replicate(cantidad_replicaciones, {
genera_valor_aleatorio_en_estrato_2(número_estrato) |>
h()
})
}
fase_de_tanteo_2 <- function(cantidad_replicaciones) {
# Asignación proporcional
n_estratos <-
(cantidad_replicaciones * probabilidades_estratos_2) |>
ceiling() |> # aseguramos una cantidad entera de valores
pmax(2) # aseguramos al menos dos valores
purrr::map2(
seq_len(cantidad_estratos_2),
n_estratos,
\(estrato, n_estrato) aplica_muestreo_en_estrato_2(estrato, n_estrato)
) |>
purrr::map_dbl(sd)
}
fase_de_producción_2 <- function(cantidad_replicaciones, sigmas) {
# Asignación óptima
n_estratos <-
(cantidad_replicaciones * probabilidades_estratos_2 * sigmas /
sum(probabilidades_estratos_2 * sigmas)) |>
ceiling() |> # aseguramos una cantidad entera de valores
pmax(2) # aseguramos al menos dos valores
purrr::map2(
seq_len(cantidad_estratos_2),
n_estratos,
\(estrato, n_estrato) aplica_muestreo_en_estrato_2(estrato, n_estrato)
)
}
sigmas_2 <- fase_de_tanteo_2(100)
valores_estratos_2 <- fase_de_producción_2(n, sigmas_2)
#| label: convergencia (muestreo estratificado)
media_ponderada <- function(total_valores) {
n_estratos <-
(total_valores * probabilidades_estratos * sigmas /
sum(probabilidades_estratos * sigmas)) |>
ceiling() |>
pmax(2)
valores <- purrr::map2(
valores_estratos,
n_estratos,
\(valores_estrato, n_estrato) valores_estrato[seq_len(n_estrato)]
)
valores |>
purrr::map_dbl(mean) |>
weighted.mean(w = probabilidades_estratos)
}
ggplot(mapping = aes(
x = seq_len(n),
y = purrr::map_dbl(seq_len(n), media_ponderada)
)) +
geom_line() +
xlab("Iteración") +
ylab("Media ponderada de las medias de los
valores aleatorios en cada estrato")
