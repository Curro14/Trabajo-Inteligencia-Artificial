# --- Gráfica 1: Distribución de Precios por Distrito ---
p1 <- ggplot(df_list, aes(x = reorder(neighbourhood_group_cleansed, price_num, FUN=median), y = price_num, fill = neighbourhood_group_cleansed)) +
geom_boxplot(alpha=0.7, outlier.size=0.5) + coord_flip() + labs(title = "Distribución de Precios por Distrito", x="", y="Precio (€)") + tema_oscuro + theme(legend.position="none")
ggsave(file.path(dir_data, "r_mkt_cajas_precios.png"), plot=p1, width=10, height=6, dpi=300)
# --- Gráfica 2: Precio Medio Oficial por Distrito ---
res_dist <- df_list %>% group_by(neighbourhood_group_cleansed) %>% summarise(precio = mean(price_num, na.rm=T))
p2 <- ggplot(res_dist, aes(x = reorder(neighbourhood_group_cleansed, precio), y = precio)) +
geom_col(fill="#e67e22", width=0.6) + geom_text(aes(label = sprintf("€%.1f", precio)), hjust=-0.2, color="white", fontface="bold") +
coord_flip() + labs(title = "Precio Medio por Distrito", x="", y="Precio Medio (€)") + tema_oscuro + scale_y_continuous(expand = expansion(mult = c(0, 0.2)))
ggsave(file.path(dir_data, "r_mkt_barras_precios.png"), plot=p2, width=10, height=6, dpi=300)
# --- Gráfica 3: Capacidad vs Precio ---
p3 <- ggplot(df_list, aes(x = factor(accommodates), y = price_num, color = room_type)) +
geom_jitter(alpha = 0.5, width = 0.2) + labs(title = "Impacto de la Capacidad en el Precio", x="Personas Permitidas", y="Precio (€)", color="Tipo") + tema_oscuro + theme(legend.position="bottom")
ggsave(file.path(dir_data, "r_mkt_capacidad_precio.png"), plot=p3, width=10, height=6, dpi=300)
# --- Gráfica 4: Superhost vs Normal (Densidad de Estrategia de Precio) ---
df_sh <- df_list %>% filter(is_superhost != "Desconocido")
p4 <- ggplot(df_sh, aes(x = price_num, fill = is_superhost)) +
geom_density(alpha = 0.5) + scale_fill_manual(values = c("#aaaaaa", "#f1c40f")) +
labs(title = "Densidad de Estrategia de Precio: Superhost vs Normal", x="Precio (€)", y="Densidad", fill="Estatus") + tema_oscuro + theme(legend.position="bottom")
ggsave(file.path(dir_data, "r_mkt_superhost_densidad.png"), plot=p4, width=10, height=6, dpi=300)
# --- Gráfica 5: Renta del Barrio vs Precio Airbnb ---
p5 <- ggplot(df_list %>% filter(!is.na(renta_num)), aes(x = renta_num, y = price_num)) +
geom_point(alpha = 0.3, color = "#3498db") + geom_smooth(method = "lm", color = "#e74c3c", se = FALSE) +
labs(title = "Correlación: Renta del Barrio vs Precio Airbnb", x="Renta Media del Distrito (€) (Datos INE)", y="Precio Noche Airbnb (€)") + tema_oscuro
ggsave(file.path(dir_data, "r_mkt_renta_vs_precio.png"), plot=p5, width=10, height=6, dpi=300)
# --- Gráfica 6: Tasa de Ocupación por Tipo de Habitación ---
p6 <- ggplot(df_list %>% filter(!is.na(ocupacion_pct)), aes(x = room_type, y = ocupacion_pct, fill = room_type)) +
geom_boxplot(alpha = 0.8) + scale_fill_brewer(palette = "Pastel1") +
labs(title = "Tasa de Ocupación por Tipo de Alojamiento", x="", y="% Ocupación Estimada") + tema_oscuro + theme(legend.position="none")
ggsave(file.path(dir_data, "r_mkt_ocupacion_tipo.png"), plot=p6, width=10, height=6, dpi=300)
# --- Gráfica 7: Validación IA: Sentimiento de Reseñas vs Estrellas (¡MÁS BONITA!) ---
# Usamos alpha más bajo para ver densidad y suavizado polinómico para la tendencia
p7 <- ggplot(df_list %>% filter(!is.na(sentimiento_num), !is.na(rating_num)), aes(x = rating_num, y = sentimiento_num)) +
geom_point(alpha = 0.3, color = "#2ecc71") + geom_smooth(method = "lm", color = "white", linetype = "dashed") +
labs(title = "Validación IA: Sentimiento de Reseñas vs Estrellas", x="Puntuación (0-5 Estrellas)", y="Score de Sentimiento (NLP)") + tema_oscuro
ggsave(file.path(dir_data, "r_ia_valid_nlp_vs_estrellas.png"), plot=p7, width=10, height=6, dpi=300)
# --- Gráfica 8: Satisfacción del Cliente por Distrito ---
res_feliz <- df_list %>% filter(!is.na(sentimiento_num)) %>% group_by(neighbourhood_group_cleansed) %>% summarise(feliz = mean(sentimiento_num, na.rm=T))
p8 <- ggplot(res_feliz, aes(x = reorder(neighbourhood_group_cleansed, feliz), y = feliz)) +
geom_segment(aes(xend=neighbourhood_group_cleansed, yend=0), color="#aaaaaa", linewidth=1) +
geom_point(color="#9b59b6", size=5) + coord_flip() +
labs(title = "Ranking de Satisfacción por Distrito", x="", y="Sentimiento Promedio (NLP)") + tema_oscuro
ggsave(file.path(dir_data, "r_ia_ranking_satisfaccion.png"), plot=p8, width=10, height=6, dpi=300)
cat("✅ ¡Proceso completado! Se han generado las 8 gráficas con éxito.\n")
# ==============================================================================
# SCRIPT DE ANÁLISIS INTEGRAL: MERCADO E IA (6 GRÁFICAS CORREGIDAS)
# ==============================================================================
if (!require(ggplot2)) install.packages("ggplot2")
if (!require(dplyr)) install.packages("dplyr")
if (!require(readr)) install.packages("readr")
library(ggplot2)
library(dplyr)
library(readr)
cat("Iniciando análisis avanzado (6 gráficas)...\n")
dir_data <- ifelse(dir.exists("../data"), "../data", "data")
ruta_list <- file.path(dir_data, "dataset_ia_final.csv")
if (!file.exists(ruta_list)) stop("❌ No se encontró dataset_ia_final.csv.")
df_list <- read_csv(ruta_list, show_col_types = FALSE)
# Limpieza profunda (Arreglado el parseo de la Renta Media)
df_list <- df_list %>%
mutate(
price_num = ifelse(is.character(price), as.numeric(gsub("[^0-9.]", "", price)), as.numeric(price)),
# Eliminamos cualquier punto de miles antes de convertir a número para que no falle la Renta
renta_num = as.numeric(gsub("[^0-9]", "", as.character(renta_media))),
ocupacion_pct = as.numeric(tasa_ocupacion) * 100,
sentimiento_num = as.numeric(score_sentimiento),
rating_num = as.numeric(review_scores_rating)
) %>%
filter(!is.na(price_num))
limite_precio <- quantile(df_list$price_num, 0.95, na.rm=TRUE)
df_list <- df_list %>% filter(price_num <= limite_precio)
# Plantilla visual premium
tema_oscuro <- theme_minimal(base_size = 14) +
theme(plot.background = element_rect(fill = "#0E1117", color = NA),
panel.background = element_rect(fill = "#0E1117", color = NA),
text = element_text(color = "white"), axis.text = element_text(color = "#cccccc"),
panel.grid.major = element_line(color = "#333333", linewidth = 0.5),
panel.grid.minor = element_blank(),
plot.title = element_text(face = "bold", color = "white", margin = margin(b = 8)),
plot.subtitle = element_text(color = "#aaaaaa", size=11, margin = margin(b = 15)),
legend.background = element_rect(fill = "#0E1117", color = NA), legend.text = element_text(color = "white"))
# 1. Cajas de Precios
p1 <- ggplot(df_list, aes(x = reorder(neighbourhood_group_cleansed, price_num, FUN=median), y = price_num, fill = neighbourhood_group_cleansed)) +
geom_boxplot(alpha=0.7, outlier.size=0.5) + coord_flip() + labs(title = "1. Distribución de Precios por Distrito", subtitle="Cajas que concentran el 50% de la oferta central", x="", y="Precio (€)") + tema_oscuro + theme(legend.position="none")
ggsave(file.path(dir_data, "r_1_cajas_precios.png"), plot=p1, width=10, height=6, dpi=300)
# 2. Barras de Precios
res_dist <- df_list %>% group_by(neighbourhood_group_cleansed) %>% summarise(precio = mean(price_num, na.rm=T))
p2 <- ggplot(res_dist, aes(x = reorder(neighbourhood_group_cleansed, precio), y = precio)) +
geom_col(fill="#e67e22", width=0.6) + geom_text(aes(label = sprintf("€%.1f", precio)), hjust=-0.2, color="white", fontface="bold") +
coord_flip() + labs(title = "2. Precio Medio por Distrito", subtitle="Ranking de zonas por precio de la noche", x="", y="Precio Medio (€)") + tema_oscuro + scale_y_continuous(expand = expansion(mult = c(0, 0.2)))
ggsave(file.path(dir_data, "r_2_barras_precios.png"), plot=p2, width=10, height=6, dpi=300)
# 3. Capacidad vs Precio
p3 <- ggplot(df_list, aes(x = factor(accommodates), y = price_num, color = room_type)) +
geom_jitter(alpha = 0.6, width = 0.25) + scale_color_brewer(palette = "Set2") +
labs(title = "3. Impacto de la Capacidad en el Precio", subtitle="Dispersión por número máximo de huéspedes", x="Huéspedes Permitidos", y="Precio (€)", color="Tipo") + tema_oscuro + theme(legend.position="bottom")
ggsave(file.path(dir_data, "r_3_capacidad_precio.png"), plot=p3, width=10, height=6, dpi=300)
# 4. Renta vs Precio (Corregida)
df_renta <- df_list %>% filter(!is.na(renta_num) & renta_num > 0)
p4 <- ggplot(df_renta, aes(x = renta_num, y = price_num)) +
geom_point(alpha = 0.4, color = "#3498db", size=2) +
geom_smooth(method = "lm", color = "#e74c3c", fill="#e74c3c", alpha=0.2) +
labs(title = "4. Renta del Barrio vs Precio Airbnb", subtitle="Correlación entre el nivel de vida (INE) y el precio turístico", x="Renta Media del Distrito (€)", y="Precio Noche Airbnb (€)") + tema_oscuro
ggsave(file.path(dir_data, "r_4_renta_vs_precio.png"), plot=p4, width=10, height=6, dpi=300)
# 5. Ocupación por tipo
df_ocu <- df_list %>% filter(!is.na(ocupacion_pct))
p5 <- ggplot(df_ocu, aes(x = room_type, y = ocupacion_pct, fill = room_type)) +
geom_boxplot(alpha = 0.8, outlier.color="#aaaaaa") + scale_fill_brewer(palette = "Pastel1") +
labs(title = "5. Tasa de Ocupación por Tipo de Alojamiento", subtitle="Probabilidad anual de que el alojamiento esté reservado", x="", y="% Ocupación Estimada") + tema_oscuro + theme(legend.position="none")
ggsave(file.path(dir_data, "r_5_ocupacion_tipo.png"), plot=p5, width=10, height=6, dpi=300)
# 6. Validación NLP vs Estrellas (Mejorada visualmente)
df_nlp <- df_list %>% filter(!is.na(sentimiento_num) & !is.na(rating_num))
p6 <- ggplot(df_nlp, aes(x = rating_num, y = sentimiento_num)) +
geom_jitter(width = 0.15, height = 0.02, alpha = 0.4, color = "#2ecc71", size = 2) +
geom_smooth(method = "lm", color = "#ff9ff3", fill = "#ff9ff3", alpha = 0.2, linewidth = 1.2) +
labs(title = "6. Validación IA: Sentimiento NLP vs Estrellas", subtitle="Correlación entre el texto analizado por IA y la puntuación manual", x="Puntuación Oficial (0-5)", y="Score de Sentimiento (NLP)") + tema_oscuro
ggsave(file.path(dir_data, "r_6_nlp_vs_estrellas.png"), plot=p6, width=10, height=6, dpi=300)
cat("✅ ¡Proceso completado! 6 gráficas generadas.\n")
