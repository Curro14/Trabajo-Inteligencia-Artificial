# ====================================================================
# ANÁLISIS ESPACIAL: MAPA TOTAL DE SEVILLA (AJUSTADO)
# ====================================================================
library(sf)
library(ggplot2)
library(dplyr)
library(readr)
library(leaflet)
library(htmlwidgets)
# 1. Carga de datos
ruta_airbnb <- "../data/listings_limpio.csv"
ruta_renta <- "../data/renta_sevilla_capital_limpio.csv"
ruta_poligonos <- "../data/mapa_sevilla_urbano.geojson"
airbnb_df <- read_csv(ruta_airbnb, show_col_types = FALSE)
renta_df <- read_csv(ruta_renta, show_col_types = FALSE)
mapa_base <- st_read(ruta_poligonos, quiet = TRUE)
# ====================================================================
# 2. Preprocesamiento (Cruce de datos)
# ====================================================================
mapa_base$CDIS_num <- as.numeric(as.character(mapa_base$CDIS))
renta_df$Distritos_num <- as.numeric(sub(".*distrito (\\d+).*", "\\1", as.character(renta_df$Distritos), ignore.case = TRUE))
renta_df$Total_num <- as.numeric(gsub("\\.", "", as.character(renta_df$Total)) %>% gsub(",", ".", .))
renta_resumen <- renta_df %>%
group_by(Distritos_num) %>%
summarise(Renta_Media = mean(Total_num, na.rm = TRUE))
mapa_final_sf <- st_transform(mapa_base %>% left_join(renta_resumen, by = c("CDIS_num" = "Distritos_num")), 4326)
airbnb_final_sf <- airbnb_df %>%
filter(!is.na(longitude) & !is.na(latitude)) %>%
st_as_sf(coords = c("longitude", "latitude"), crs = 4326)
# ====================================================================
# 3. MAPA ESTÁTICO (PNG) - COORDENADAS OPTIMIZADAS POR MÍ
# ====================================================================
mapa_estatico <- ggplot() +
geom_sf(data = mapa_final_sf, aes(fill = Renta_Media), color = "white", linewidth = 0.1) +
scale_fill_distiller(palette = "YlGnBu", direction = 1, na.value = "#F2F4F4", name = "Renta (€)") +
geom_sf(data = airbnb_final_sf, color = "#E74C3C", size = 0.8, alpha = 0.3) +
# He abierto los límites para que se vea todo el término municipal
coord_sf(xlim = c(-6.08, -5.82),
ylim = c(37.30, 37.47),
expand = FALSE) +
theme_void() +
theme(
plot.background = element_rect(fill = "white", color = NA),
plot.title = element_text(size = 18, face = "bold", hjust = 0.5, margin = margin(t=20, b=10)),
plot.subtitle = element_text(size = 11, hjust = 0.5, color = "#666666", margin = margin(b=20)),
legend.position = "bottom",
legend.key.width = unit(2, "cm")
) +
labs(title = "Sevilla: Nivel de Renta y Presión de Airbnb",
subtitle = "Vista completa del municipio (Distritos y Secciones Censales)")
ggsave("../data/mapa_estatico_renta_airbnb.png", plot = mapa_estatico, width = 12, height = 10, bg = "white")
# ====================================================================
# 4. MAPA INTERACTIVO (HTML) - VISTA INICIAL CORREGIDA
# ====================================================================
pal <- colorNumeric("YlGnBu", domain = mapa_final_sf$Renta_Media, na.color = "#F2F4F4")
mapa_interactivo <- leaflet() %>%
addProviderTiles(providers$CartoDB.Positron) %>%
# He bajado el zoom a 11 para que al abrirlo se vea la ciudad entera de un golpe
setView(lng = -5.95, lat = 37.39, zoom = 11) %>%
addPolygons(data = mapa_final_sf,
fillColor = ~pal(Renta_Media),
weight = 1, color = "white", fillOpacity = 0.6,
popup = ~paste("Distrito:", CDIS_num, "<br>Renta:", round(Renta_Media, 2), "€")) %>%
addCircleMarkers(data = airbnb_final_sf,
radius = 2, color = "#E74C3C", stroke = FALSE, fillOpacity = 0.4) %>%
addLegend(pal = pal, values = mapa_final_sf$Renta_Media, title = "Renta (€)")
saveWidget(mapa_interactivo, file = "../data/mapa_interactivo_renta.html", selfcontained = TRUE)
# ====================================================================
# ANÁLISIS ESPACIAL: MAPA MUNICIPAL COMPLETO (Renta vs Airbnb)
# ====================================================================
library(sf)
library(ggplot2)
library(dplyr)
library(readr)
library(leaflet)
library(htmlwidgets)
# 1. Carga de datos
ruta_airbnb <- "../data/listings_limpio.csv"
ruta_renta <- "../data/renta_sevilla_capital_limpio.csv"
# Cambiamos al archivo de mapa completo
ruta_poligonos <- "../data/mapa_sevilla.geojson"
airbnb_df <- read_csv(ruta_airbnb, show_col_types = FALSE)
renta_df <- read_csv(ruta_renta, show_col_types = FALSE)
mapa_base <- st_read(ruta_poligonos, quiet = TRUE)
# ====================================================================
# 2. Preprocesamiento y Cruce
# ====================================================================
# Estandarización de identificadores
mapa_base$CDIS_num <- as.numeric(as.character(mapa_base$CDIS))
renta_df$Distritos_num <- as.numeric(sub(".*distrito (\\d+).*", "\\1",
as.character(renta_df$Distritos),
ignore.case = TRUE))
# Limpieza de valores de renta
renta_df$Total_num <- as.numeric(gsub("\\.", "", as.character(renta_df$Total)) %>% gsub(",", ".", .))
# Agrupación por distrito
renta_resumen <- renta_df %>%
group_by(Distritos_num) %>%
summarise(Renta_Media = mean(Total_num, na.rm = TRUE))
# Join sobre el mapa completo
mapa_con_renta <- mapa_base %>%
left_join(renta_resumen, by = c("CDIS_num" = "Distritos_num"))
# Conversión a sistema de coordenadas geográficas (WGS84)
mapa_final_sf <- st_transform(mapa_con_renta, 4326)
airbnb_final_sf <- airbnb_df %>%
filter(!is.na(longitude) & !is.na(latitude)) %>%
st_as_sf(coords = c("longitude", "latitude"), crs = 4326)
# ====================================================================
# 3. MAPA ESTÁTICO (Encuadre basado en el mapa completo)
# ====================================================================
# Calculamos los límites basados en el mapa municipal completo
limites_municipio <- st_bbox(mapa_final_sf)
mapa_estatico <- ggplot() +
geom_sf(data = mapa_final_sf, aes(fill = Renta_Media), color = "white", linewidth = 0.1) +
scale_fill_distiller(palette = "YlGnBu", direction = 1, na.value = "#F2F4F4", name = "Renta (€)") +
geom_sf(data = airbnb_final_sf, color = "#E74C3C", size = 0.8, alpha = 0.3) +
# Forzamos el encuadre a la extensión total del archivo geojson
coord_sf(xlim = c(limites_municipio["xmin"], limites_municipio["xmax"]),
ylim = c(limites_municipio["ymin"], limites_municipio["ymax"]),
expand = TRUE) +
theme_void() +
theme(
plot.background = element_rect(fill = "white", color = NA),
plot.title = element_text(size = 18, face = "bold", hjust = 0.5, margin = margin(t=20, b=10)),
legend.position = "bottom",
legend.key.width = unit(2, "cm")
) +
labs(title = "Sevilla: Distribución Municipal de Renta y Airbnb")
ggsave("../data/mapa_estatico_renta_airbnb.png", plot = mapa_estatico, width = 12, height = 10, bg = "white")
# ====================================================================
# 4. MAPA INTERACTIVO (Leaflet)
# ====================================================================
pal <- colorNumeric("YlGnBu", domain = mapa_final_sf$Renta_Media, na.color = "#F2F4F4")
mapa_interactivo <- leaflet() %>%
addProviderTiles(providers$CartoDB.Positron) %>%
# Ajustamos la vista para que se vea el municipio completo al inicio
fitBounds(lng1 = limites_municipio["xmin"], lat1 = limites_municipio["ymin"],
lng2 = limites_municipio["xmax"], lat2 = limites_municipio["ymax"]) %>%
addPolygons(data = mapa_final_sf,
fillColor = ~pal(Renta_Media),
weight = 1, color = "white", fillOpacity = 0.6,
popup = ~paste("Distrito:", CDIS_num, "<br>Renta:", round(Renta_Media, 2), "€")) %>%
addCircleMarkers(data = airbnb_final_sf,
radius = 2, color = "#E74C3C", stroke = FALSE, fillOpacity = 0.4) %>%
addLegend(pal = pal, values = mapa_final_sf$Renta_Media, title = "Renta (€)")
saveWidget(mapa_interactivo, file = "../data/mapa_interactivo_renta.html", selfcontained = TRUE)
# ====================================================================
# ANÁLISIS ESPACIAL: SEVILLA COMPLETO (Renta vs Airbnb)
# ====================================================================
library(sf)
library(ggplot2)
library(dplyr)
library(readr)
library(leaflet)
library(htmlwidgets)
# 1. Carga de datos
ruta_airbnb <- "../data/listings_limpio.csv"
ruta_renta <- "../data/renta_sevilla_capital_limpio.csv"
ruta_poligonos <- "../data/mapa_sevilla.geojson" # Usamos el mapa municipal completo
airbnb_df <- read_csv(ruta_airbnb, show_col_types = FALSE)
renta_df <- read_csv(ruta_renta, show_col_types = FALSE)
mapa_base <- st_read(ruta_poligonos, quiet = TRUE)
# ====================================================================
# 2. Preprocesamiento (Cero dependencias de Python)
# ====================================================================
# Limpieza de identificadores de distrito
mapa_base$CDIS_num <- as.numeric(as.character(mapa_base$CDIS))
renta_df$Distritos_num <- as.numeric(sub(".*distrito (\\d+).*", "\\1",
as.character(renta_df$Distritos),
ignore.case = TRUE))
# Limpieza de valores de renta (manejo de puntos y comas)
renta_df$Total_num <- as.numeric(gsub("\\.", "", as.character(renta_df$Total)) %>% gsub(",", ".", .))
# Agrupación por distrito (Media)
renta_resumen <- renta_df %>%
group_by(Distritos_num) %>%
summarise(Renta_Media = mean(Total_num, na.rm = TRUE))
# Join y Proyección a WGS84 (estándar GPS)
mapa_final_sf <- mapa_base %>%
left_join(renta_resumen, by = c("CDIS_num" = "Distritos_num")) %>%
st_transform(4326)
airbnb_final_sf <- airbnb_df %>%
filter(!is.na(longitude) & !is.na(latitude)) %>%
st_as_sf(coords = c("longitude", "latitude"), crs = 4326)
# ====================================================================
# 3. MAPA ESTÁTICO (PNG) - ENCUADRE MUNICIPAL COMPLETO
# ====================================================================
# Calculamos límites basados en el polígono municipal completo
limites <- st_bbox(mapa_final_sf)
mapa_estatico <- ggplot() +
geom_sf(data = mapa_final_sf, aes(fill = Renta_Media), color = "white", linewidth = 0.1) +
scale_fill_distiller(palette = "YlGnBu", direction = 1, na.value = "#F2F4F4", name = "Renta (€)") +
geom_sf(data = airbnb_final_sf, color = "#E74C3C", size = 0.7, alpha = 0.3) +
coord_sf(xlim = c(limites["xmin"], limites["xmax"]),
ylim = c(limites["ymin"], limites["ymax"]),
expand = TRUE) +
theme_void() +
theme(
plot.background = element_rect(fill = "white", color = NA),
plot.title = element_text(size = 18, face = "bold", hjust = 0.5, margin = margin(t=20, b=10)),
legend.position = "bottom",
legend.key.width = unit(2, "cm")
) +
labs(title = "Sevilla: Nivel de Renta y Alojamientos Turísticos")
ggsave("../data/mapa_estatico_renta_airbnb.png", plot = mapa_estatico, width = 12, height = 10, bg = "white")
# ====================================================================
# 4. MAPA INTERACTIVO (HTML) - SIN AVISOS DE JSON
# ====================================================================
# Extraemos los valores sin nombres para evitar los warnings de jsonlite
valores_renta <- unname(mapa_final_sf$Renta_Media)
pal <- colorNumeric("YlGnBu", domain = valores_renta, na.color = "#F2F4F4")
mapa_interactivo <- leaflet() %>%
addProviderTiles(providers$CartoDB.Positron) %>%
fitBounds(lng1 = limites["xmin"], lat1 = limites["ymin"],
lng2 = limites["xmax"], lat2 = limites["ymax"]) %>%
addPolygons(data = mapa_final_sf,
fillColor = ~pal(Renta_Media),
weight = 1, color = "white", fillOpacity = 0.6,
popup = ~paste("Distrito:", CDIS_num, "<br>Renta:", round(Renta_Media, 2), "€")) %>%
addCircleMarkers(data = airbnb_final_sf,
radius = 2, color = "#E74C3C", stroke = FALSE, fillOpacity = 0.4) %>%
addLegend(pal = pal, values = valores_renta, opacity = 0.7, title = "Renta (€)")
# Guardamos silenciando avisos internos
suppressWarnings({
saveWidget(mapa_interactivo, file = "../data/mapa_interactivo_renta.html", selfcontained = TRUE)
})
